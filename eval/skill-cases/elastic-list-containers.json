{
  "id": "elastic-list-containers",
  "category": "elastic-private-cloud",
  "prompt": "Use the autodl skill to show the command for listing containers under deployment deploy-abc123. Do not call live APIs.",
  "expected": {
    "skill": "autodl",
    "namespace": "elastic",
    "must_include": [
      "autodl.mjs elastic",
      "containers",
      "--deployment-uuid deploy-abc123",
      "/api/v1/dev/deployment/container/list",
      "https://private.autodl.com"
    ],
    "must_not_include": [
      "autodl.mjs pro",
      "instance_uuid",
      "/api/v1/dev/instance/pro/status",
      "https://api.autodl.com"
    ],
    "must_not_do": [
      "call_live_api",
      "execute_cli"
    ]
  },
  "scoring": {
    "max_score": 10,
    "rubric": [
      {"points": 2, "criterion": "Selects the elastic namespace."},
      {"points": 2, "criterion": "Uses containers command with deployment UUID flag."},
      {"points": 2, "criterion": "Maps to deployment container list endpoint."},
      {"points": 2, "criterion": "Uses private cloud host."},
      {"points": 2, "criterion": "Does not call live API or use Pro instance terminology."}
    ]
  }
}
