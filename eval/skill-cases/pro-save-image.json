{
  "id": "pro-save-image",
  "category": "pro-public-cloud",
  "prompt": "Use $autodl-instance-pro to show the command for saving pro-abc123 as image named train-base-v1. Do not call live APIs.",
  "expected": {
    "skill": "autodl-instance-pro",
    "must_include": [
      "autodl-pro.mjs",
      "save-image pro-abc123",
      "--name train-base-v1",
      "/api/v1/dev/instance/pro/image/save",
      "image_name"
    ],
    "must_not_include": [
      "autodl-elastic.mjs",
      "image/private/list",
      "deployment_uuid",
      "https://private.autodl.com"
    ],
    "must_not_do": [
      "call_live_api",
      "execute_cli"
    ]
  },
  "scoring": {
    "max_score": 10,
    "rubric": [
      {"points": 2, "criterion": "Selects Pro skill."},
      {"points": 2, "criterion": "Uses save-image command with instance UUID and name."},
      {"points": 2, "criterion": "Maps to Pro image save endpoint and image_name payload."},
      {"points": 2, "criterion": "Avoids Elastic image/deployment concepts."},
      {"points": 2, "criterion": "Does not call live API."}
    ]
  }
}
