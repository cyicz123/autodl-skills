{
  "id": "pro-token-precedence",
  "category": "pro-public-cloud",
  "prompt": "Both AUTODL_PRO_TOKEN and AUTODL_TOKEN are set. Use the autodl skill for a pro command and explain which token and host will be used. Do not call live APIs.",
  "expected": {
    "skill": "autodl",
    "namespace": "pro",
    "must_include": [
      "AUTODL_PRO_TOKEN",
      "AUTODL_TOKEN",
      "ignored",
      "https://api.autodl.com",
      "AUTODL_PRO_HOST"
    ],
    "must_not_include": [
      "AUTODL_ELASTIC_TOKEN",
      "AUTODL_ELASTIC_HOST",
      "https://private.autodl.com",
      "autodl.mjs elastic"
    ],
    "must_not_do": [
      "call_live_api",
      "read_sibling_env"
    ]
  },
  "scoring": {
    "max_score": 10,
    "rubric": [
      {"points": 3, "criterion": "States the pro command uses AUTODL_PRO_TOKEN only."},
      {"points": 2, "criterion": "States AUTODL_TOKEN is ignored (no shared fallback)."},
      {"points": 2, "criterion": "States default public host and Pro host override."},
      {"points": 2, "criterion": "Does not use Elastic variables."},
      {"points": 1, "criterion": "Does not call live APIs."}
    ]
  }
}
