{
  "id": "pro-status-dry-run",
  "category": "pro-public-cloud",
  "prompt": "Use the autodl skill to check the status of pro-abc123, but do not call live APIs. Show the command and endpoint.",
  "expected": {
    "skill": "autodl",
    "namespace": "pro",
    "must_include": [
      "autodl.mjs pro",
      "status pro-abc123",
      "/api/v1/dev/instance/pro/status",
      "https://api.autodl.com",
      "AUTODL_PRO_TOKEN"
    ],
    "must_not_include": [
      "autodl.mjs elastic",
      "https://private.autodl.com",
      "AUTODL_ELASTIC_TOKEN",
      "deployment_uuid"
    ],
    "must_not_do": [
      "call_live_api",
      "execute_cli"
    ]
  },
  "scoring": {
    "max_score": 10,
    "rubric": [
      {"points": 2, "criterion": "Selects the autodl pro namespace."},
      {"points": 2, "criterion": "Uses node autodl.mjs pro status command."},
      {"points": 2, "criterion": "Maps to Pro status endpoint with instance_uuid."},
      {"points": 2, "criterion": "Uses public cloud host/token namespace."},
      {"points": 2, "criterion": "Does not call live APIs."}
    ]
  }
}
